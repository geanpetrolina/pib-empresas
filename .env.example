# ============================================================================
# PIB EMPRESAS — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA cometa o .env.local no Git.
# ============================================================================

# Supabase — encontrados em Project Settings > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Service Role Key — usada SOMENTE em API routes server-side (nunca no client)
# Necessária para: webhooks de notificação, cron de aniversários, devocional IA
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# OpenAI — para geração da Devocional IA
OPENAI_API_KEY=sk-sua_chave_openai_aqui
OPENAI_MODEL=gpt-4o-mini

# n8n — URL base da sua instância (usada como referência/documentação;
# os webhooks reais ficam salvos na tabela webhook_configs via interface)
N8N_BASE_URL=https://automacao.agencia7up.com.br

# Segredo para validar chamadas recebidas em /api/webhooks/n8n (opcional, recomendado)
WEBHOOK_INBOUND_SECRET=defina_um_segredo_forte_aqui

# Segredo para proteger o endpoint de cron de aniversários
# (chamado diariamente por um agendador externo, ex: cron-job.org ou n8n Schedule Trigger)
CRON_SECRET=defina_outro_segredo_forte_aqui

# URL pública da aplicação (usada em links de notificação)
NEXT_PUBLIC_APP_URL=http://localhost:3000
